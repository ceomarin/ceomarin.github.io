---
import "../styles/global.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/700.css";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>404 — Página no encontrada</title>
    </head>
    <body
        class="bg-slate-950 text-slate-100 antialiased"
        style="font-family: 'Inter', sans-serif;"
    >
        <div
            class="min-h-screen flex flex-col items-center justify-center px-6 text-center"
        >
            <p
                class="text-8xl font-bold bg-gradient-to-r from-indigo-400 via-violet-400 to-purple-400 bg-clip-text text-transparent mb-4"
            >
                404
            </p>

            <h1 class="text-2xl font-semibold text-white mb-3">
                Página no encontrada
            </h1>

            <p class="text-slate-400 max-w-sm mb-8">
                La URL que buscas no existe o fue movida. Volvamos a un lugar
                seguro.
            </p>

            <a
                href="/"
                class="px-6 py-3 rounded-lg bg-gradient-to-r from-indigo-600 via-violet-600 to-purple-600 text-white font-semibold hover:opacity-90 transition-opacity"
            >
                Volver al inicio
            </a>
        </div>
    </body>
</html>
